{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "H3 Warranty",
  "type": "object",
  "required": ["schema_version", "warranty_id"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "warranty_id": {
      "type": "string"
    },
    "asset_id": {
      "type": "string"
    },
    "contract_id": {
      "type": "string"
    },
    "supplier_id": {
      "type": "string"
    },
    "start_date": {
      "type": "string",
      "format": "date"
    },
    "end_date": {
      "type": "string",
      "format": "date"
    },
    "terms": {
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}