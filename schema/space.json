{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "H3 Space",
  "type": "object",
  "required": ["schema_version", "space_id", "building_id"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "space_id": {
      "type": "string"
    },
    "building_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": ["room", "zone", "floor", "area", "other"]
    },
    "floor": {
      "type": "integer"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}