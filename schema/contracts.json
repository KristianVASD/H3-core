{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "H3 Contract",
  "type": "object",
  "required": ["schema_version", "contract_id", "building_id"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "contract_id": {
      "type": "string"
    },
    "building_id": {
      "type": "string"
    },
    "supplier_id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": ["warranty", "maintenance", "service"]
    },
    "start_date": {
      "type": "string",
      "format": "date"
    },
    "end_date": {
      "type": "string",
      "format": "date"
    },
    "details": {
      "type": "object",
      "additionalProperties": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}