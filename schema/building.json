{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "H3 Building",
  "type": "object",
  "required": ["schema_version", "building_id"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "building_id": {
      "type": "string",
      "description": "Globally unique building identifier (e.g. NL.BAG.xxx)"
    },
    "name": {
      "type": "string"
    },
    "address": {
      "type": "string"
    },
    "city": {
      "type": "string"
    },
    "country": {
      "type": "string",
      "default": "NL"
    },
    "construction_year": {
      "type": "integer"
    },
    "function": {
      "type": "array",
      "items": { "type": "string" }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}