{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "H3 Event",
  "type": "object",
  "required": ["schema_version", "event_id", "asset_id", "building_id", "event_type"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "event_id": {
      "type": "string"
    },
    "asset_id": {
      "type": "string"
    },
    "building_id": {
      "type": "string"
    },

    "event_type": {
      "type": "string",
      "enum": ["failure", "maintenance", "inspection", "replacement", "complaint", "other"]
    },

    "category": {
      "type": "string"
    },

    "description": {
      "type": "string"
    },

    "reported_by": {
      "type": "string"
    },

    "reported_at": {
      "type": "string",
      "format": "date-time"
    },

    "status": {
      "type": "string",
      "enum": ["open", "in_progress", "resolved", "closed"]
    },

    "severity": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },

    "context": {
      "type": "object",
      "additionalProperties": true
    },

    "resolution": {
      "type": "object",
      "properties": {
        "resolved_at": {
          "type": "string",
          "format": "date-time"
        },
        "resolved_by": {
          "type": "string"
        },
        "action_taken": {
          "type": "string"
        }
      }
    },

    "ai_enrichment": {
      "type": "object",
      "properties": {
        "predicted_cause": { "type": "string" },
        "recommended_action": { "type": "string" },
        "responsible_party": { "type": "string" },
        "confidence": { "type": "number" }
      }
    },

    "metadata": {
      "type": "object",
      "additionalProperties": true
    },

    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}